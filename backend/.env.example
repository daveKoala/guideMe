# Backend configuration. Copy to .env and override per-machine.
# Precedence: built-in defaults < .env < real environment variables.

# HTTP server port
PORT=8080

# Runtime environment: development | production
ENV=development

# SQLite database file path
DB_PATH=./guide-me.db

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info

# Document blob storage backend: local
BLOB_BACKEND=local

# Local blob backend directory (used when BLOB_BACKEND=local)
BLOB_DIR=./blobs
